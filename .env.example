# Supabase — values from your project's Settings > API Keys and Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SERVER-ONLY — never commit the real value; keep it only in .env.local.
SUPABASE_SECRET_KEY=

# MapTiler — browser-visible map tiles key.
NEXT_PUBLIC_MAPTILER_KEY=

# The site's public base URL (used for sitemap + social share links).
NEXT_PUBLIC_SITE_URL=
