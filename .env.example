# Supabase — values from your project's Settings > API Keys and Settings > API
# Safe to expose in the browser (Next.js "NEXT_PUBLIC_" prefix = client-visible):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SERVER-ONLY — no NEXT_PUBLIC prefix so Next.js never bundles it into the browser.
# Never commit the real value; keep it only in .env.local.
SUPABASE_SECRET_KEY=
